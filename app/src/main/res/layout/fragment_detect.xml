<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="漏磁监测波形 (6 Channels)" android:textColor="#00FFFF" android:textSize="11sp"/>

    <com.example.mavlinktest.RealtimeGraphView
        android:id="@+id/multiDataGraph"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#050A1A"
        android:layout_marginTop="4dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—— 升降台控制 ——" android:textColor="#88CCFF" android:gravity="center" android:layout_marginTop="15dp" android:textSize="12sp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp">
        <Button android:id="@+id/btnDetectUp" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:text="上升 (Up)" android:backgroundTint="#1565C0"/>
        <Button android:id="@+id/btnDetectDown" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:text="下降 (Down)" android:backgroundTint="#1565C0" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—— 卡钳夹紧机构 ——" android:textColor="#88CCFF" android:gravity="center" android:layout_marginTop="15dp" android:textSize="12sp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp">
        <Button android:id="@+id/btnDetectClamp" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:text="夹紧 (Clamp)" android:backgroundTint="#D84315"/>
        <Button android:id="@+id/btnDetectRelease" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:text="松开 (Release)" android:backgroundTint="#2E7D32" android:layout_marginStart="4dp"/>
    </LinearLayout>
</LinearLayout>